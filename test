        $updates = Invoke-RestMethod -Uri "$apiUrl/getUpdates?offset=$($lastId + 1)&timeout=20" -ErrorAction Stop
        foreach ($u in $updates.result) {
            $lastId = $u.update_id
            $msgText = $u.message.text
